            android:fillColor="#FFFFFF"
            android:pathData="M47,39 L61,39 L61,70 L47,70 Z" />
        <!-- a thin shade down one side of the body for depth -->
        <path
            android:fillColor="#D7DCEC"
            android:pathData="M56,39 L61,39 L61,70 L56,70 Z" />
        <!-- wood tip -->
        <path
            android:fillColor="#FFFFFF"
